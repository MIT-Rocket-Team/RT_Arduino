  gpsSer.write(cfg2, sizeof(cfg2));
  gpsSer.write(cfg1, sizeof(cfg1));
  gpsSer.begin(115200);

}

void loop() {
  // put your main code here, to run repeatedly:
  //debugSer.println("HELLO WORLD!");
